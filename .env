# ============================================================
#  CENTRALISED ENVIRONMENT CONFIGURATION
# ============================================================

# ── Environment ──────────────────────────────────────────────
NODE_ENV=development

# ── Signaling Server ─────────────────────────────────────────
SIGNALING_PORT=4000
SIGNALING_HOST=0.0.0.0
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long!
SESSION_TTL_SECONDS=3600

# ── TURN / Coturn ─────────────────────────────────────────────
TURN_REALM=localhost
TURN_SERVER_IP=127.0.0.1
TURN_PORT=3478
TURNS_PORT=5349
TURN_USERNAME=turnuser
TURN_PASSWORD=turnpassword123
TURN_MIN_PORT=49152
TURN_MAX_PORT=65535

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redispassword123
REDIS_TTL=7200

# ── SSL / TLS (production) ────────────────────────────────────
SSL_CERT_PATH=/certs/fullchain.pem
SSL_KEY_PATH=/certs/privkey.pem

# ── STUN servers (comma-separated) ───────────────────────────
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# ── WebRTC ────────────────────────────────────────────────────
WEBRTC_MAX_BITRATE_KBPS=8000
WEBRTC_MIN_BITRATE_KBPS=500
WEBRTC_MAX_FPS=60

# ── Frontend (Vite) ───────────────────────────────────────────
# Leave blank to auto-detect from window.location at runtime
VITE_SIGNAL_URL=wss://7df8-122-164-126-153.ngrok-free.app/ws
VITE_TURN_SERVER=turn:free.expressturn.com:3478
VITE_TURN_USERNAME=000000002090920579
VITE_TURN_PASSWORD=A/cL63fLtcF4cWl+y0MpDpzZ7dg=

# ── Electron / Desktop App ────────────────────────────────────
SIGNALING_URL=wss://7df8-122-164-126-153.ngrok-free.app/ws 
APP_LOG_LEVEL=debug
